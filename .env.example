# ===================================
# Contacts Application - Environment Variables
# ===================================
# Copy this file to .env and fill in the values
# DO NOT commit .env to version control

# ===================================
# Google OAuth Configuration
# ===================================
# Get these from Google Cloud Console: https://console.cloud.google.com/apis/credentials
# Make sure to configure:
# - Authorized redirect URIs: http://localhost:5000/api/auth/callback
# - Authorized JavaScript origins: http://localhost:3002
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret

# Backend API base URL (for Docker deployment)
REACT_APP_API_BASE_URL=http://localhost:5000/api

# ===================================
# Database Configuration (PostgreSQL)
# ===================================
# PostgreSQL credentials
POSTGRES_USER=contactsapi
POSTGRES_PASSWORD=YourStrong!Passw0rd
POSTGRES_DB=contactsdb

# ===================================
# Environment
# ===================================
NODE_ENV=production
