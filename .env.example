# Contacts Application Environment Configuration
# Copy this file to .env and fill in your actual values
# DO NOT COMMIT .env TO GIT - only .env.example should be committed

# Google OAuth Configuration (Story 1.3)
# Create OAuth credentials at: https://console.cloud.google.com/apis/credentials
# Required scopes: https://www.googleapis.com/auth/contacts
REACT_APP_GOOGLE_CLIENT_ID=<your-client-id-here>.apps.googleusercontent.com

# Google People API Base URL
# This is the base URL for Google People API v1
REACT_APP_API_BASE_URL=https://people.googleapis.com/v1

# Environment
# Set to 'development', 'production', or 'test'
NODE_ENV=development
