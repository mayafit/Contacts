{
  "Serilog": {
    "Using": ["Serilog.Sinks.Console", "Serilog.Sinks.File"],
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.AspNetCore": "Warning",
        "System": "Warning"
      }
    },
    "WriteTo": [
      {
        "Name": "Console",
        "Args": {
          "formatter": "Serilog.Formatting.Compact.CompactJsonFormatter, Serilog.Formatting.Compact"
        }
      },
      {
        "Name": "File",
        "Args": {
          "path": "logs/contacts-api-.log",
          "rollingInterval": "Day",
          "formatter": "Serilog.Formatting.Compact.CompactJsonFormatter, Serilog.Formatting.Compact"
        }
      }
    ],
    "Enrich": ["FromLogContext", "WithMachineName", "WithThreadId"]
  },
  "GoogleOAuth": {
    "ClientId": "816988902915-75ndeue7pj4llc4lgots23se79ckutg2.apps.googleusercontent.com",
    "ClientSecret": "",
    "RedirectUri": "http://localhost:5000/api/auth/callback",
    "Scopes": [
      "openid",
      "profile",
      "email",
      "https://www.googleapis.com/auth/contacts.readonly"
    ]
  },
  "Redis": {
    "ConnectionString": "localhost:6379",
    "InstanceName": "ContactsApi:"
  },
  "Database": {
    "ConnectionString": "Server=localhost;Database=ContactsDb;Trusted_Connection=true;TrustServerCertificate=true;"
  },
  "Cors": {
    "AllowedOrigins": ["http://localhost:3000"],
    "AllowCredentials": true
  },
  "Session": {
    "CookieName": ".ContactsApi.Session",
    "IdleTimeout": 7,
    "SlidingExpiration": true
  },
  "AllowedHosts": "*"
}
